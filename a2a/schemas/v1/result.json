      "$ref": "common.json#/$defs/header"
    }
  ],
  "properties": {
    "protocol": {
      "const": "io.choria.fisk-ai.v1.result"
    },
    "stop_reason": {
      "$ref": "common.json#/$defs/stop_reason"
    },
    "text": {
      "type": "string",

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://choria.io/schemas/io.choria.fisk-ai.v1/session.terminal.json",
  "title": "fisk-ai session store v1 terminal record",
  "allOf": [
    {
      "$ref": "session.common.json#/$defs/envelope"
    }
  ],
  "properties": {
    "protocol": {
      "const": "io.choria.fisk-ai.v1.session.terminal"
    },
    "terminal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reason"
      ],
      "properties": {
        "reason": {
          "type": "string",
          "enum": [
            "completed",
            "suspended",
            "error",
            "budget",
            "max_iterations"
          ]
        },
        "message": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "terminal"
  ],
  "unevaluatedProperties": false
}
